    {
      "parameters": {
        "jsCode": "const subjects = ['語文', '數學', '英語', '物理', '化學'];\n\nconst studentsWithStats = items.map(item => {\n  const s = item.json;\n  const scores = subjects.map(sub => s[sub]);\n  const total = scores.reduce((a, b) => a + b, 0);\n  const avg = (total / subjects.length).toFixed(1);\n  let grade;\n  if (avg >= 90) grade = 'A';\n  else if (avg >= 80) grade = 'B';\n  else if (avg >= 70) grade = 'C';\n  else if (avg >= 60) grade = 'D';\n  else grade = 'F';\n  return { json: { ...s, 總分: total, 平均分: parseFloat(avg), 等第: grade } };\n});\n\nstudentsWithStats.sort((a, b) => b.json.總分 - a.json.總分);\nstudentsWithStats.forEach((item, idx) => { item.json.班級排名 = idx + 1; });\n\nconst classStats = {};\nsubjects.forEach(sub => {\n  const scores = items.map(i => i.json[sub]);\n  classStats[sub + '_班平均'] = parseFloat((scores.reduce((a,b) => a+b, 0) / scores.length).toFixed(1));\n  classStats[sub + '_最高分'] = Math.max(...scores);\n  classStats[sub + '_最低分'] = Math.min(...scores);\n});\n\nreturn studentsWithStats.map(item => ({ json: { ...item.json, ...classStats } }));"
      },
